# ============================================================
# LEVERAGE AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ─────────────────────────────────────────────────────────────
# REQUIRED — App will not start without these
# ─────────────────────────────────────────────────────────────

# xAI Grok API key — get yours at https://console.x.ai/
XAI_API_KEY=

# The Odds API key — get yours at https://the-odds-api.com/
ODDS_API_KEY=

# Supabase project URL — from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key — same location as above
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (SECRET — server-side only, never prefix with NEXT_PUBLIC_)
# Same location: Settings → API → Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — App degrades gracefully without these
# ─────────────────────────────────────────────────────────────

# Public site URL — used for absolute links and OG tags
# In production set this to your Vercel URL, e.g. https://leverage-desk.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Kalshi prediction markets — bearer token (public markets only)
# Get from https://kalshi.com → Account → API
KALSHI_API_KEY=

# Kalshi RSA-authenticated trading (advanced — leave blank for public markets only)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# Stripe — required only for subscription gating
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
