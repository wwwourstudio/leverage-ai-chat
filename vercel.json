{
  "functions": {
    "app/api/analyze/route.ts": {
      "maxDuration": 60
    },
    "app/api/cards/route.ts": {
      "maxDuration": 20
    },
    "app/api/mlb-projections/route.ts": {
      "maxDuration": 25
    },
    "app/api/daily-picks/route.ts": {
      "maxDuration": 60
    },
    "app/api/picks/route.ts": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/daily-picks",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/adp/refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/odds",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/projections",
      "schedule": "0 0,8,16 * * *"
    },
    {
      "path": "/api/cron/picks",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/train",
      "schedule": "0 3 * * *"
    }
  ]
}
