{
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/all", "schedule": "0 8 * * *" }
  ],
  "functions": {
    "app/api/cron/all/route.ts": {
      "maxDuration": 60
    },
    "app/api/analyze/route.ts": {
      "maxDuration": 60
    },
    "app/api/cards/route.ts": {
      "maxDuration": 20
    },
    "app/api/mlb-projections/route.ts": {
      "maxDuration": 25
    },
    "app/api/daily-picks/route.ts": {
      "maxDuration": 60
    },
    "app/api/picks/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/odds/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/projections/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/picks/route.ts": {
      "maxDuration": 20
    },
    "app/api/cron/train/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/statcast/route.ts": {
      "maxDuration": 45
    },
    "app/api/cron/dfs/route.ts": {
      "maxDuration": 45
    },
    "app/api/cron/weather/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/settle/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/kalshi/route.ts": {
      "maxDuration": 45
    },
    "app/api/cron/props/route.ts": {
      "maxDuration": 30
    }
  }
}
